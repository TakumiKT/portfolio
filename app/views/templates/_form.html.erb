<% if template.errors.any? %>
  <div class="card" style="border-color:#f3a3a3;">
    <p><strong>入力内容を確認してください</strong></p>
    <ul>
      <% template.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="form-field">
  <%= f.label :name, "テンプレート名（必須）" %><br>
  <%= f.text_field :name, class: "form-field__input",
        placeholder: "例：かぜ / 頭痛 / 小児 / 妊娠授乳" %>
</div>

<div class="form-field">
  <%= f.label :symptom_hint, "相談内容・症状（例/質問例）" %><br>
  <%= f.text_area :symptom_hint, rows: 3, class: "form-field__textarea",
        placeholder: "例：いつから？どの部位？熱は？咳は？…" %>
</div>

<div class="form-field">
  <%= f.label :check_point_hint, "接客時に確認したポイント（例/質問例）" %><br>
  <%= f.text_area :check_point_hint, rows: 3, class: "form-field__textarea",
        placeholder: "例：妊娠/授乳、年齢、持病、服薬、アレルギー…" %>
</div>

<div class="form-field">
  <%= f.label :judgment_hint, "自分の判断・対応内容（例）" %><br>
  <%= f.text_area :judgment_hint, rows: 3, class: "form-field__textarea",
        placeholder: "例：受診勧奨の要否、提案する成分、注意点の説明…" %>
</div>

<div class="form-field">
  <%= f.label :concern_point_hint, "注意点・迷った点（任意）" %><br>
  <%= f.text_area :concern_point_hint, rows: 3, class: "form-field__textarea",
        placeholder: "例：禁忌に該当しそう/判断材料が不足…など" %>
</div>

<div class="form-field">
  <%= f.label :reflection_hint, "振り返り・改善点（任意）" %><br>
  <%= f.text_area :reflection_hint, rows: 3, class: "form-field__textarea",
        placeholder: "例：次回はこの確認を最初に入れる、説明順を改善…" %>
</div>

<div class="form-field">
  <%= f.label :tag_names_hint, "タグ候補（カンマ区切り・任意）" %><br>
  <%= f.text_field :tag_names_hint, class: "form-field__input",
        placeholder: "例：かぜ, 小児, 禁忌確認" %>
</div>

<div class="form-actions">
  <%= f.submit "登録する", class: "btn btn--primary" %>
  <%= link_to "戻る", templates_path, class: "btn btn--sub" %>
</div>