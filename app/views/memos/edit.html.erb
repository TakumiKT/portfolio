<div class="page-head page-head--with-actions">
  <div>
    <h1 class="page-title">メモ（詳細・編集）</h1>
    <p class="note">内容を更新できます。不要になったメモは削除できます。</p>
  </div>

  <div class="page-actions">
    <%= link_to "削除", memo_path(@memo),
          class: "btn btn--danger",
          data: { turbo_method: :delete, turbo_confirm: "削除しますか？" } %>
  </div>
</div>
<%= button_to "AIフィードバックを生成",
      ai_feedback_memo_path(@memo),
      method: :post,
      class: "btn btn--sub",
      form: { data: { turbo: false } },
      data: { disable_with: "生成中..." } %>
<p class="note">※ 学習・振り返り用途のフィードバックです。医療判断の代替ではありません。</p>

<div class="ai-usage-note">
  本日のAIフィードバック：<%= ai_used(:feedback) %>/<%= AiUsageHelper::FEEDBACK_LIMIT %> 回（残り <%= ai_remaining(:feedback) %> 回）
</div>

<%= form_with model: @memo do |f| %>
  <%= render "form", f: f, memo: @memo %>
  <% ai = current_user.ai_results.where(kind: "feedback", memo_id: @memo.id).order(created_at: :desc).first %>
  <% if ai.present? %>
    <section class="card">
      <h2>AIフィードバック</h2>
      <p class="note">生成日時：<%= l(ai.created_at) %></p>
      <pre class="ai-output"><%= ai.content %></pre>
      <pre style="white-space: pre-wrap;"><%= ai.content %></pre>
    </section>
  <% end %>
<% end %>