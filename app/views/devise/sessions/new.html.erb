<div class="auth-card">
  <h1 class="auth-title">ログイン</h1>

  <%= form_for(resource,
               as: resource_name,
               url: session_path(resource_name),
               html: { class: "auth-form" }) do |f| %>

    <% if flash.alert.present? %>
      <div class="auth-errors">
        <ul><li><%= flash.alert %></li></ul>
      </div>
    <% end %>

    <div class="auth-field">
      <%= f.label :email, "メールアドレス" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
    </div>

    <div class="auth-field">
      <%= f.label :password, "パスワード" %>
      <%= f.password_field :password, autocomplete: "current-password" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="auth-field auth-field--inline">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, "ログイン状態を保持する" %>
      </div>
    <% end %>

    <div class="auth-actions">
      <%= f.submit "ログイン",
            class: "btn btn--primary",
            data: { turbo_submits_with: "ログイン中..." } %>
    </div>
  <% end %>

  <%# ---- フォーム外 ---- %>
  <div class="auth-divider"></div>

  <div class="auth-actions">
    <%= button_to "Googleアカウントでログイン",
          user_google_oauth2_omniauth_authorize_path,
          method: :post,
          class: "btn btn--sub auth-google-btn",
          data: { turbo: false } %>
  </div>


  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>


