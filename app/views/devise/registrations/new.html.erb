<h2><%= t("devise.registrations.new.title") %></h2>

<div class="auth-card">
  <h1 class="auth-title"><%= t("devise.registrations.new.title") %></h1>
  <div class="form-consent">
    登録することで
    <%= link_to "利用規約", terms_path, target: "_blank", rel: "noopener", class: "form-consent__link" %>、
    <%= link_to "プライバシーポリシー", privacy_path, target: "_blank", rel: "noopener", class: "form-consent__link" %>
    に同意したものとみなします。
  </div>
  <%= form_for(resource,
               as: resource_name,
               url: registration_path(resource_name),
               html: { class: "auth-form" }) do |f| %>

    <%# エラーメッセージ表示 %>
    <% if resource.errors.any? %>
      <div class="auth-errors">
        <ul>
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="auth-field">
      <%= f.label :name, "名前" %>
      <%= f.text_field :name, autofocus: true, autocomplete: "name" %>
    </div>

    <div class="auth-field">
      <%= f.label :email, "メールアドレス" %>
      <%= f.email_field :email, autocomplete: "email" %>
    </div>

    <div class="auth-field">
      <%= f.label :password, "パスワード" %>
      <%= f.password_field :password, autocomplete: "new-password" %>
    </div>

    <div class="auth-field">
      <%= f.label :password_confirmation, "パスワード（確認）" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
    </div>

    <div class="auth-actions">
      <%= f.submit t("devise.registrations.new.submit"), class: "btn btn--primary" %>
    </div>

  <% end %>
  <div class="auth-divider">
    <span>または</span>
  </div>

  <div class="auth-actions">
    <%= button_to "Googleでログイン",
          user_google_oauth2_omniauth_authorize_path,
          method: :post,
          class: "btn btn--sub auth-google-btn",
          data: { turbo: false } %>
  </div>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>